# 火山引擎 (OmniHuman数字人 + TTS)
VOLC_ACCESS_KEY=your_volc_access_key
VOLC_SECRET_KEY=your_volc_secret_key

# Claude API (文案生成)
ANTHROPIC_API_KEY=your_anthropic_api_key

# MiniMax (TTS配音)
MINIMAX_API_KEY=your_minimax_api_key

# Pexels (素材搜索)
PEXELS_API_KEY=你的PexelsAPIKey
# OpenNews 免费素材图复用限制：同一张图 24 小时内最多使用 3 次，单个批次内不重复。
OPENNEWS_PEXELS_IMAGE_DAILY_LIMIT=3
# OpenNews 免费素材匹配：默认严格要求图片自身描述命中文案实体/领域/场景。
OPENNEWS_PEXELS_STRICT_MATCH_ENABLED=1
OPENNEWS_PEXELS_MIN_RELEVANCE_SCORE=28
# OpenNews 自动发布：重复图默认只警告不阻断；设为 1 可恢复硬阻断。
OPENNEWS_AUTO_PUBLISH_DUPLICATE_IMAGE_BLOCKING=0
OPENNEWS_COLLECTION_DUPLICATE_IMAGE_BLOCKING=0

# 火山方舟 Seedream 5.0 Lite（管理员主播图生成）
ARK_API_KEY=你的ArkApiKey
ARK_IMAGE_MODEL=doubao-seedream-5-0-lite-260128

# X / Twitter 自动发布
X_CONSUMER_KEY=your_x_consumer_key
X_CONSUMER_SECRET=your_x_consumer_secret
X_BEARER_TOKEN=your_x_bearer_token
X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_SECRET=your_x_oauth2_client_secret
X_REDIRECT_URI=https://aiagent.office.ihousejapan.cn/api/x/oauth/callback
# OAuth 回调后会自动保存 access/refresh token 到 output/x_auth/x_token.json，通常不用手填 X_ACCESS_TOKEN。
OPENNEWS_X_AUTO_PUBLISH_ENABLED=0
OPENNEWS_X_AUTO_PUBLISH_DISABLED=0
OPENNEWS_X_PUBLISH_SINGLE_SHORTS_ENABLED=1
OPENNEWS_X_PUBLISH_COLLECTION_ENABLED=0
